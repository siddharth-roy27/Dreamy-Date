# ── DreamyDate Environment Configuration ─────────────
# Copy this file to .env.local and fill in your values.
# .env is for defaults / non-secret values committed to git.
# .env.local is for secrets and overrides (gitignored).

# ── Application ───────────────────────────────────────
VITE_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dreamydate
MONGODB_URI=mongodb://localhost:27017/dreamydate_media
REDIS_URL=redis://localhost:6379

# ── Authentication ────────────────────────────────────
JWT_SECRET=change-me-in-production
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Spotify Integration ───────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/spotify/callback

# ── OpenAI / AI Services ─────────────────────────────
OPENAI_API_KEY=
RUNWAYML_API_KEY=
STABILITY_API_KEY=

# ── AWS S3 (Media Storage) ───────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=dreamydate-media
AWS_REGION=us-east-1
